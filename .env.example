# --- Root environment for docker-compose ---
# Copy to .env and adjust as needed: `cp .env.example .env`

# PostgreSQL
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpass
POSTGRES_DB=taskdb

# Backend
JWT_SECRET=please-change-me-to-a-long-random-secret
JWT_EXPIRY=24h
BCRYPT_COST=12

# Frontend (baked in at build time)
NEXT_PUBLIC_API_URL=http://localhost:8080
