# --- Backend configuration ---

# PostgreSQL connection string.
DATABASE_URL=postgres://taskuser:taskpass@localhost:5432/taskdb?sslmode=disable

# Secret used to sign JWTs. MUST be at least 16 characters. Use a long random
# value in production (e.g. `openssl rand -base64 32`).
JWT_SECRET=please-change-me-to-a-long-random-secret

# How long an issued token stays valid (Go duration syntax: 24h, 30m, etc).
JWT_EXPIRY=24h

# Port the API listens on.
PORT=8080

# Origin allowed by CORS (the frontend URL).
CORS_ORIGIN=http://localhost:3000

# bcrypt cost factor (10-14 is typical; higher is slower but stronger).
BCRYPT_COST=12

# Run database migrations automatically on startup.
RUN_MIGRATIONS=true
